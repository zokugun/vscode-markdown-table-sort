{
	"name": "markdown-table-sort",
	"displayName": "Markdown Table Sort",
	"description": "Quickly sort a Markdown table",
	"version": "0.1.0",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"publisher": "zokugun",
	"license": "MIT",
	"homepage": "https://github.com/zokugun/vscode-markdown-table-sort",
	"repository": {
		"type": "git",
		"url": "https://github.com/zokugun/vscode-markdown-table-sort.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/vscode-markdown-table-sort/issues"
	},
	"engines": {
		"vscode": "^1.75.0"
	},
	"main": "./lib/index.js",
	"browser": "./lib/index.js",
	"scripts": {
		"audit:fix": "npm audit fix --min-release-age=0",
		"build": "npm run clean && npm run compile:src && npm run bundle",
		"bundle": "ncc build out/extension --out lib",
		"ci:lint": "zizmor .",
		"ci:lint:fix": "zizmor . --fix=all",
		"clean": "rimraf lib; rimraf out *.vsix",
		"compile:src": "tsc -p src",
		"lint": "xo",
		"lint:all": "npm run lint:package && npm audit && npm run ci:lint && npm run lint",
		"lint:fix": "xo --fix",
		"lint:package": "fixpack || true",
		"package": "rimraf *.vsix && vsce package",
		"prepare": "husky; npm run lint:package",
		"release": "release-it",
		"update:artifacts": "artifact update",
		"update:ci": "PINACT_MIN_AGE=7 pinact run --update",
		"update:deps": "taze --all",
		"vscode:prepublish": "npm run build",
		"watch:src": "tsc-watch -p src --onSuccess 'npm run bundle'"
	},
	"dependencies": {},
	"devDependencies": {
		"@commitlint/cli": "20.5.3",
		"@commitlint/config-conventional": "20.5.3",
		"@types/node": "20.19.43",
		"@types/vscode": "1.56.0",
		"@vercel/ncc": "0.44.0",
		"@vscode/vsce": "3.9.2",
		"fixpack": "4.0.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"release-it": "20.2.0",
		"rimraf": "6.1.3",
		"taze": "19.14.1",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3",
		"xo": "0.60.0"
	},
	"overrides": {
		"release-it": {
			"undici": "7.28.0"
		}
	},
	"allowScripts": {
		"@vscode/vsce-sign": true,
		"keytar": true
	},
	"activationEvents": [
		"onLanguage:markdown",
		"onLanguage:mdx",
		"onLanguage:quarto"
	],
	"capabilities": {
		"virtualWorkspaces": true,
		"untrustedWorkspaces": {
			"supported": true
		}
	},
	"contributes": {
		"commands": [
			{
				"command": "markdownTableSort.sortNumberAsc",
				"title": "Markdown Table Sort: Number Asc"
			},
			{
				"command": "markdownTableSort.sortNumberDesc",
				"title": "Markdown Table Sort: Number Desc"
			},
			{
				"command": "markdownTableSort.sortTextAsc",
				"title": "Markdown Table Sort: Text Asc"
			},
			{
				"command": "markdownTableSort.sortTextDesc",
				"title": "Markdown Table Sort: Text Desc"
			}
		],
		"configuration": {
			"title": "Markdown Table Sort",
			"properties": {
				"markdownTableSort.notification": {
					"type": "string",
					"enum": [
						"none",
						"major",
						"minor",
						"patch"
					],
					"default": "minor",
					"description": "Display notification when a new version is installed",
					"enumDescriptions": [
						"The new version notification won't be shown anymore.",
						"The new version notification will be shown only with a new major version",
						"The new version notification will be shown only with a new minor version",
						"The new version notification will always be shown"
					],
					"scope": "application",
					"tags": [
						"markdown",
						"table"
					]
				},
				"markdownTableSort.showMenu.sortNumberAsc": {
					"type": "boolean",
					"default": true,
					"description": "Show command in context menu: \"Number Asc\".",
					"scope": "application",
					"tags": [
						"markdown",
						"table"
					]
				},
				"markdownTableSort.showMenu.sortNumberDesc": {
					"type": "boolean",
					"default": true,
					"description": "Show command in context menu: \"Number Desc\".",
					"scope": "application",
					"tags": [
						"markdown",
						"table"
					]
				},
				"markdownTableSort.showMenu.sortTextAsc": {
					"type": "boolean",
					"default": true,
					"description": "Show command in context menu: \"Text Asc\".",
					"scope": "application",
					"tags": [
						"markdown",
						"table"
					]
				},
				"markdownTableSort.showMenu.sortTextDesc": {
					"type": "boolean",
					"default": true,
					"description": "Show command in context menu: \"Text Desc\".",
					"scope": "application",
					"tags": [
						"markdown",
						"table"
					]
				}
			}
		},
		"keybindings": [
			{
				"command": "markdownTableSort.sortNumberAsc",
				"key": "alt+r down",
				"when": "editorTextFocus && !editorReadonly && !editorTabMovesFocus && !suggestWidgetMultipleSuggestions && !suggestWidgetVisible && !inSnippetMode && markdownTableSort.contextkey.selection.InMarkdownTable"
			},
			{
				"command": "markdownTableSort.sortNumberDesc",
				"key": "alt+r up",
				"when": "editorTextFocus && !editorReadonly && !editorTabMovesFocus && !suggestWidgetMultipleSuggestions && !suggestWidgetVisible && !inSnippetMode && markdownTableSort.contextkey.selection.InMarkdownTable"
			},
			{
				"command": "markdownTableSort.sortTextAsc",
				"key": "alt+t down",
				"when": "editorTextFocus && !editorReadonly && !editorTabMovesFocus && !suggestWidgetMultipleSuggestions && !suggestWidgetVisible && !inSnippetMode && markdownTableSort.contextkey.selection.InMarkdownTable"
			},
			{
				"command": "markdownTableSort.sortTextDesc",
				"key": "alt+t up",
				"when": "editorTextFocus && !editorReadonly && !editorTabMovesFocus && !suggestWidgetMultipleSuggestions && !suggestWidgetVisible && !inSnippetMode && markdownTableSort.contextkey.selection.InMarkdownTable"
			}
		],
		"menus": {
			"editor/context": [
				{
					"when": "markdownTableSort.contextkey.active.IsSupportedLanguage && markdownTableSort.contextkey.selection.InMarkdownTable && markdownTableSort.contextkey.config.showMenu.sortNumberAsc",
					"command": "markdownTableSort.sortNumberAsc",
					"group": "markdownTableSort@1"
				},
				{
					"when": "markdownTableSort.contextkey.active.IsSupportedLanguage && markdownTableSort.contextkey.selection.InMarkdownTable && markdownTableSort.contextkey.config.showMenu.sortNumberDesc",
					"command": "markdownTableSort.sortNumberDesc",
					"group": "markdownTableSort@2"
				},
				{
					"when": "markdownTableSort.contextkey.active.IsSupportedLanguage && markdownTableSort.contextkey.selection.InMarkdownTable && markdownTableSort.contextkey.config.showMenu.sortTextAsc",
					"command": "markdownTableSort.sortTextAsc",
					"group": "markdownTableSort@3"
				},
				{
					"when": "markdownTableSort.contextkey.active.IsSupportedLanguage && markdownTableSort.contextkey.selection.InMarkdownTable && markdownTableSort.contextkey.config.showMenu.sortTextDesc",
					"command": "markdownTableSort.sortTextDesc",
					"group": "markdownTableSort@4"
				}
			]
		}
	},
	"icon": "icon.png",
	"galleryBanner": {
		"color": "#ffffff",
		"theme": "light"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"markdown",
		"sort",
		"sorting",
		"table"
	],
	"extensionKind": [
		"ui",
		"workspace"
	]
}
